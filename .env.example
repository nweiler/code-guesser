# Google Analytics Data API credentials
# 1. Go to https://console.cloud.google.com/ → your project → APIs & Services
# 2. Enable "Google Analytics Data API"
# 3. Create a service account, download the JSON key
# 4. In GA4 admin → Property Access Management, add that service account email as Viewer
# 5. Find your numeric property ID in GA4 Admin → Property Settings → Property ID

GA_PROPERTY_ID=
GA_CREDENTIALS=

# Auth.js (GitHub OAuth)
# Get a client ID/secret at: https://github.com/settings/developers
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Database (Vercel Postgres / Neon)
POSTGRES_URL=
